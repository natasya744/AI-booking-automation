    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nif (items.length === 0) {\n  return [];\n}\n\n// Ambil AI output\nconst aiOutput = items[0].json.output ?? {};\nconst aiData = aiOutput.customer_data ?? {};\n\n// Normalisasi agar tidak undefined\nconst result = {\n  event_type: aiData.event_type ?? null,\n  customer_name: aiData.customer_name ?? null,\n  phone_number: aiData.phone_number ?? null,\n  package_name: aiData.package_name ?? null,\n  address: aiData.address ?? null,\n  request: aiData.request ?? null,\n  event_date: aiData.event_date ?? null,\n  baby_name: aiData.baby_name ?? null,\n  baby_photo: null, // memang tidak dari AI\n  partner_name: aiData.partner_names ?? null,\n  birthday_name: aiData.birthday_name ?? null,\n  turn_age: aiData.turn_age ?? null,\n  lock_date: aiData.lock_date ?? null\n};\n\nconsole.log(\"EXTRACTED FROM AI:\", result);\n\nreturn [\n  {\n    json: result\n  }\n];\n"
      },
