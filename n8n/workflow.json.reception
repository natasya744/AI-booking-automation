    {
      "parameters": {
        "schemaType": "manual",
        "inputSchema": "{\n  \"name\": \"decoration_intent_parser\",\n  \"description\": \"Parse user messages into a single decoration-related intent with structured fields\",\n  \"schema\": {\n    \"type\": \"object\",\n    \"properties\": {\n      \"intent\": {\n        \"type\": \"string\",\n        \"description\": \"Single intent only\",\n        \"enum\": [\n          \"availability_check\",\n          \"booking_request\",\n          \"reschedule_event\",\n          \"cancel_booking\",\n          \"complaint\",\n          \"general_question\"\n        ]\n      },\n      \"event_type\": {\n        \"type\": [\"string\", \"null\"],\n        \"description\": \"Type of event such as aqiqah, wedding, birthday\"\n      },\n      \"event_date\": {\n        \"type\": [\"string\", \"null\"],\n        \"description\": \"Event date in YYYY-MM-DD format\"\n      },\n      \"client_name\": {\n        \"type\": [\"string\", \"null\"],\n        \"description\": \"Client name if mentioned\"\n      },\n      \"package_name\": {\n        \"type\": [\"string\", \"null\"],\n        \"description\": \"Decoration package name if mentioned\"\n      },\n      \"partner_names\": {\n        \"type\": [\"string\", \"null\"],\n        \"description\": \"Names of partners for engagement or wedding\"\n      },\n      \"baby_name\": {\n        \"type\": [\"string\", \"null\"],\n        \"description\": \"Baby name for aqiqah events\"\n      },\n      \"urgency\": {\n        \"type\": \"string\",\n        \"enum\": [\"low\", \"medium\", \"high\"]\n      },\n      \"confidence\": {\n        \"type\": \"number\",\n        \"minimum\": 0,\n        \"maximum\": 1\n      }\n    },\n    \"required\": [\n      \"intent\",\n      \"urgency\",\n      \"confidence\"\n    ],\n    \"additionalProperties\": false\n  }\n}\n",
        "autoFix": "={{ false }}"
      },
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
      "typeVersion": 1.3,
      "position": [
        -3728,
